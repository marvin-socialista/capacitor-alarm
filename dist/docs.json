          }
        ],
        "returns": "Promise<NativeActionResult>",
        "tags": [
          {
            "name": "param",
            "text": "options - Options for creating the alarm"
          },
          {
            "name": "returns",
            "text": "Promise that resolves with `{ success, id? }`. `id` is the UUID\nthat can be passed to `cancelAlarm`."
          },
          {
            "name": "since",
            "text": "1.0.0"
          }
        ],
        "docs": "Create a native OS alarm.\nOn Android the alarm is scheduled via `AlarmManager.setExactAndAllowWhileIdle`\nand owned by this app (cancellable, survives reboot via a boot receiver).\nOn iOS 26+ the alarm is scheduled via AlarmKit.",
        "complexTypes": [
          "NativeActionResult",
          "NativeAlarmCreateOptions"
        ],
        "slug": "createalarm"
      },
      {
        "name": "cancelAlarm",
        "signature": "(options: { id: string; }) => Promise<NativeActionResult>",
