            "type": "{ id: string; }"
          }
        ],
        "returns": "Promise<NativeActionResult>",
        "tags": [
          {
            "name": "param",
            "text": "options - `{ id }` of the alarm to cancel"
          },
          {
            "name": "returns",
            "text": "`{ success: true }` if the alarm was cancelled (or did not exist);\n`{ success: false, message }` on error."
          },
          {
            "name": "since",
            "text": "8.1.0"
          }
        ],
        "docs": "Cancel a previously scheduled alarm by its id.",
        "complexTypes": [
          "NativeActionResult"
        ],
        "slug": "cancelalarm"
